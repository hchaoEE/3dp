    "uuid": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/uuid": "latest",
    "prisma": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
